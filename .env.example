# Copy this file to .env and fill in your values
# Register your app at https://developers.eveonline.com/

# --- EVE SSO ---
EVE_CLIENT_ID=your_client_id_here
EVE_CLIENT_SECRET=your_client_secret_here
EVE_CALLBACK_URL=http://localhost:8000/auth/callback

# --- Security ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your_fernet_key_here

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=your_session_secret_here

# --- App Config ---
APP_PORT=8000
DEBUG=true

# --- Your Corporation ---
# Your corporation's EVE Online ID (find at https://evewho.com/)
YOUR_CORP_ID=0
YOUR_ALLIANCE_ID=0   # 0 if no alliance
# Additional corps allowed recruiter access (comma-separated)
ALLOWED_CORP_IDS=819141869,98226285

# --- Database ---
DATABASE_URL=sqlite:///./esi_checker.db
